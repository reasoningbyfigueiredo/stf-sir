{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stf-sir.org/schemas/zmd-v1.schema.json",
  "title": "STF-SIR .zmd v1 artifact",
  "description": "Structural schema for STF-SIR v1 artifacts. Cross-reference invariants (unique ids, counts, reference resolution, exact source-slice equality) are enforced by the Rust semantic validator, not by this schema.",
  "type": "object",
  "required": [
    "format",
    "version",
    "source",
    "compiler",
    "document",
    "ztokens",
    "relations",
    "diagnostics"
  ],
  "additionalProperties": true,
  "properties": {
    "format": {
      "type": "string",
      "const": "stf-sir.zmd"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "source": { "$ref": "#/$defs/source" },
    "compiler": { "$ref": "#/$defs/compiler" },
    "document": { "$ref": "#/$defs/document" },
    "ztokens": {
      "type": "array",
      "items": { "$ref": "#/$defs/ztoken" }
    },
    "relations": {
      "type": "array",
      "items": { "$ref": "#/$defs/relation" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    },
    "extensions": {
      "type": "object"
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["media_type", "encoding", "length_bytes", "sha256"],
      "properties": {
        "path": { "type": "string" },
        "media_type": {
          "type": "string",
          "const": "text/markdown"
        },
        "encoding": {
          "type": "string",
          "const": "utf-8"
        },
        "length_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": { "type": "string" }
      }
    },
    "compiler": {
      "type": "object",
      "required": ["name", "version", "config_hash"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "config_hash": { "type": "string" },
        "profile": { "type": "string" }
      }
    },
    "document": {
      "type": "object",
      "required": ["language", "token_count", "relation_count", "root_token_ids"],
      "properties": {
        "language": { "type": "string" },
        "token_count": {
          "type": "integer",
          "minimum": 0
        },
        "relation_count": {
          "type": "integer",
          "minimum": 0
        },
        "root_token_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "span": {
      "type": "object",
      "required": ["start_byte", "end_byte", "start_line", "end_line"],
      "properties": {
        "start_byte": {
          "type": "integer",
          "minimum": 0
        },
        "end_byte": {
          "type": "integer",
          "minimum": 0
        },
        "start_line": {
          "type": "integer",
          "minimum": 1
        },
        "end_line": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "lexical": {
      "type": "object",
      "required": ["source_text", "plain_text", "normalized_text", "span"],
      "properties": {
        "source_text": { "type": "string" },
        "plain_text": { "type": "string" },
        "normalized_text": { "type": "string" },
        "span": { "$ref": "#/$defs/span" }
      }
    },
    "syntactic": {
      "type": "object",
      "required": ["node_type", "parent_id", "depth", "sibling_index", "path"],
      "properties": {
        "node_type": { "type": "string" },
        "parent_id": {
          "type": ["string", "null"]
        },
        "depth": {
          "type": "integer",
          "minimum": 0
        },
        "sibling_index": {
          "type": "integer",
          "minimum": 0
        },
        "path": { "type": "string" }
      }
    },
    "semantic": {
      "type": "object",
      "required": ["gloss"],
      "properties": {
        "gloss": { "type": "string" },
        "concepts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "logical": {
      "type": "object",
      "required": ["relation_ids"],
      "properties": {
        "relation_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ztoken": {
      "type": "object",
      "required": ["id", "L", "S", "Σ", "Φ"],
      "properties": {
        "id": { "type": "string" },
        "L": { "$ref": "#/$defs/lexical" },
        "S": { "$ref": "#/$defs/syntactic" },
        "Σ": { "$ref": "#/$defs/semantic" },
        "Φ": { "$ref": "#/$defs/logical" },
        "extensions": { "type": "object" }
      }
    },
    "relation": {
      "type": "object",
      "required": ["id", "type", "category", "source", "target", "stage"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "category": {
          "description": "Relation classification. This is orthogonal to `stage`.",
          "type": "string",
          "enum": ["structural", "logical", "semantic-link"]
        },
        "source": { "type": "string" },
        "target": { "type": "string" },
        "stage": {
          "description": "Pipeline stage that emitted the relation. This is provenance, not semantic type.",
          "type": "string",
          "enum": ["lexical", "syntactic", "semantic", "logical"]
        },
        "attributes": { "type": "object" },
        "extensions": { "type": "object" }
      }
    },
    "diagnostic": {
      "type": "object",
      "required": ["code", "severity", "message", "stage"],
      "properties": {
        "code": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        },
        "message": { "type": "string" },
        "token_id": { "type": "string" },
        "stage": {
          "type": "string",
          "enum": ["lexical", "syntactic", "semantic", "logical", "validation"]
        }
      }
    }
  }
}
